# Application
BACKEND_ENVIRONMENT=development
BACKEND_APP_PORT=8000
BACKEND_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
BACKEND_LOG_LEVEL=INFO
BACKEND_VERSION=0.1.0

# Database
# For local SQLite: sqlite+aiosqlite:///./council.db
# For production PostgreSQL (asyncpg): postgresql+asyncpg://user:password@host:port/dbname
BACKEND_DATABASE_URL=sqlite+aiosqlite:///./council.db

# JWT & Authentication
BACKEND_JWT_SECRET_KEY=super-secret-jwt-key-for-development-only-change-in-prod
BACKEND_JWT_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudinary & Documents
BACKEND_CLOUDINARY_CLOUD_NAME=your_cloud_name
BACKEND_CLOUDINARY_API_KEY=your_api_key
BACKEND_CLOUDINARY_API_SECRET=your_api_secret
BACKEND_MAX_UPLOAD_SIZE_MB=10
BACKEND_ALLOWED_DOCUMENT_TYPES=application/pdf,text/plain,text/markdown

# RAG & Embeddings
BACKEND_CHUNK_SIZE=1000
BACKEND_CHUNK_OVERLAP=200
BACKEND_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# FAISS Lifecycle
BACKEND_FAISS_INDEX_CLOUDINARY_FOLDER=faiss_indexes
BACKEND_INGESTION_STUCK_THRESHOLD_MINUTES=15

# Groq & Reasoning Agents
BACKEND_GROQ_API_KEY=your_groq_api_key
BACKEND_REASONING_MODEL_NAME=llama-3.1-8b-instant
BACKEND_AGENT_TIMEOUT_SECONDS=15

# Aggregator
BACKEND_AGGREGATOR_MODEL_NAME=llama-3.3-70b-versatile
BACKEND_DEFAULT_AGENT_WEIGHTS={"logical":1.0,"rational":1.0,"practical":1.0,"spiritual":1.0,"skeptical":1.0}

# Confidence Engine
BACKEND_CONFIDENCE_WEIGHT_RETRIEVAL=0.35
BACKEND_CONFIDENCE_WEIGHT_EVIDENCE=0.45
BACKEND_CONFIDENCE_WEIGHT_AGREEMENT=0.20

# Chat & Conversation History
BACKEND_MAX_CHAT_HISTORY_MESSAGES=10

# Rate Limiting
BACKEND_RATE_LIMIT_AUTH_PER_MINUTE=10/minute
BACKEND_RATE_LIMIT_QUESTIONS_PER_MINUTE=20/minute

# Database Pool & Performance
BACKEND_DB_POOL_SIZE=5
BACKEND_DB_MAX_OVERFLOW=10
